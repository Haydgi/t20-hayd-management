<div class="thm-sheet-root">
<nav class="tabs" data-group="primary">
  <a data-action="changeTab" data-group="primary" data-tab="members" class="{{#if (eq tab "members")}}active{{/if}}">
    <i class="fa-solid fa-users"></i> {{localize "THM.TabMembers"}}
  </a>
  <a data-action="changeTab" data-group="primary" data-tab="inventory" class="{{#if (eq tab "inventory")}}active{{/if}}">
    <i class="fa-solid fa-box-open"></i> {{localize "THM.TabInventory"}}
  </a>
</nav>

<section class="tab {{#if (eq tab "members")}}active{{/if}}" data-group="primary" data-tab="members">
  <div class="thm-members">
    {{#each members}}
    <div class="thm-member-card" data-actor-id="{{this.id}}">
      <img class="thm-portrait" src="{{this.img}}" alt="{{this.name}}" data-action="openActor" data-actor-id="{{this.id}}" />
      <div class="thm-member-info">
        <div class="thm-member-name">
          {{this.name}}
          {{#if this.level}}<span class="thm-member-level">{{localize "THM.Level"}} {{this.level}}</span>{{/if}}
        </div>
        {{#unless ../hideBars}}
        <div class="thm-bars">
          <div class="thm-bar thm-pv" title="PV">
            <div class="thm-bar-fill" style="width: {{this.pv.pct}}%"></div>
            <span class="thm-bar-label">{{this.pv.label}}</span>
          </div>
          <div class="thm-bar thm-pm" title="PM">
            <div class="thm-bar-fill" style="width: {{this.pm.pct}}%"></div>
            <span class="thm-bar-label">{{this.pm.label}}</span>
          </div>
          {{#if this.carga}}
          <div class="thm-bar thm-carga {{#if this.carga.encumbered}}thm-encumbered{{/if}}" title="{{localize 'THM.Encumbrance'}}">
            <div class="thm-bar-fill" style="width: {{this.carga.pct}}%"></div>
            <span class="thm-bar-label">{{this.carga.label}}</span>
          </div>
          {{/if}}
        </div>
        {{/unless}}
      </div>
    </div>
    {{else}}
    <p class="thm-empty">{{localize "THM.NoMembers"}}</p>
    {{/each}}
  </div>
</section>

<section class="tab {{#if (eq tab "inventory")}}active{{/if}}" data-group="primary" data-tab="inventory">
  <div class="thm-money-row">
    {{#if showTl}}
    <span class="thm-coin thm-coin-tl" title="{{localize 'THM.CoinTL'}}"><i class="fa-solid fa-coins"></i> {{money.tl}} TL</span>
    {{/if}}
    <span class="thm-coin thm-coin-to" title="{{localize 'THM.CoinTO'}}"><i class="fa-solid fa-coins"></i> {{money.to}} TO</span>
    <span class="thm-coin thm-coin-tp" title="{{localize 'THM.CoinTP'}}"><i class="fa-solid fa-coins"></i> {{money.tp}} TP</span>
    <span class="thm-coin thm-coin-tc" title="{{localize 'THM.CoinTC'}}"><i class="fa-solid fa-coins"></i> {{money.tc}} TC</span>
    <div class="thm-money-actions">
      <button type="button" data-action="depositMoney" title="{{localize 'THM.DepositMoneyTitle'}}">
        <i class="fa-solid fa-arrow-down"></i> {{localize "THM.DepositMoney"}}
      </button>
      <button type="button" data-action="withdrawMoney" title="{{localize 'THM.WithdrawMoneyTitle'}}">
        <i class="fa-solid fa-arrow-up"></i> {{localize "THM.WithdrawMoney"}}
      </button>
    </div>
  </div>

  <div class="thm-inv-list">
    {{#each items}}
    <div class="thm-inv-item" data-item-id="{{this.id}}" draggable="true">
      <img src="{{this.img}}" alt="{{this.name}}" />
      <span class="thm-item-name">{{this.name}}</span>
      <span class="thm-item-qty">×{{this.qtd}}</span>
      <span class="thm-item-type">{{this.typeLabel}}</span>
      <button type="button" class="thm-send-money-btn" data-action="sendStashItem" data-item-id="{{this.id}}" title="{{localize 'THM.SendTo'}}">
        <i class="fa-solid fa-paper-plane"></i>
      </button>
    </div>
    {{else}}
    <p class="thm-empty">{{localize "THM.NoItems"}}</p>
    {{/each}}
  </div>
</section>
</div>
